} else {  # method == "clusters"
# Extract clusters data
samples <- result[["samples"]]
clusters_chulls <- result[["clusters_chulls"]]
points_combined <- do.call(rbind, samples[["size_1"]][["points"]])
# Determine which level to plot
n_levels <- length(clusters_chulls)
if (is.null(level)) level <- 1
#------------ Spatial Plot ------------
if (plot_type %in% c("all", "spatial")) {
if (n_levels > 1 && plot_type == "spatial") {
# Plot all levels in grid
n_cols <- ceiling(sqrt(n_levels))
n_rows <- ceiling(n_levels / n_cols)
par(mfrow = c(n_rows, n_cols), mar = c(2, 2, 3, 2))
level_names <- names(clusters_chulls)
for (lvl in 1:n_levels) {
plot_spatial_clusters(
points = points_combined,
hulls = clusters_chulls[[lvl]],
level_name = level_names[lvl]
)
}
par(mfrow = c(1, 1), mar = c(5, 4, 4, 2))
} else {
# Single level
plot_spatial_clusters(
points = points_combined,
hulls = clusters_chulls[[level]],
level_name = names(clusters_chulls)[level]
)
}
}
#------------ SAR Plot ------------
if (plot_type %in% c("all", "sar")) {
sar_results <- result[["sar_analysis"]]
if (sar_results$valid) {
plot_sar(sar_results, "Clusters")
} else {
cat("SAR analysis not valid\n")
cat("Message:", sar_results$message, "\n")
}
}
}
#------------ Heatmap / CSAR Summary (if available) ------------
if (has_csar) {
csar_res <- result[["csar_analysis"]]
if (plot_type == "heatmap") {
print(plot_heatmap(csar_res))
} else if (plot_type == "csar_summary") {
print_csar_summary(csar_res)
} else if (plot_type == "all") {
print_csar_summary(csar_res)
cat("\n")
print(plot_heatmap(csar_res))
}
} else if (plot_type %in% c("heatmap", "csar_summary")) {
cat("Countryside SAR analysis not available in this result object.\n")
}
# Return invisible
invisible(result)
}
# Helper function for %||% operator (null coalescing)
`%||%` <- function(x, y) if (is.null(x)) y else x
# Helper function for circles data preparation
prepare_circles_for_plot <- function(result, run_number = 1) {
samples <- result[["runs"]][[run_number]][["samples"]]
circle_polygons <- lapply(samples, `[[`, "circle")
return(list(
points = result[["points_sf"]],
circles = circle_polygons,
hull = result[["convex_hull"]]
))
}
