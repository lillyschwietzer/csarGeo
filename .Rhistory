if (!is.null(seed)) set.seed(seed)
#---------------------------- 1. Input validation ----------------------------
method <- match.arg(method)
if (!"long" %in% names(data) || !"lat" %in% names(data))
stop("Data must contain 'long' and 'lat' columns.")
if (is.null(crs)) stop("Coordinate reference system (crs) must be provided.")
if (ncol(data) < 4)
stop("Data must have at least 4 columns: locationID, long, lat, and species data.")
if (method == "circles") {
if (is.null(radii)) stop("'radii' is required for method = 'circles'.")
if (!is.numeric(radii) || any(radii <= 0))
stop("'radii' must be a positive numeric vector.")
} else { # clusters
if (is.null(square_size) || is.null(cluster_sizes))
stop("'square_size' and 'cluster_sizes' are required for method = 'clusters'.")
if (!is.numeric(square_size) || square_size <= 0)
stop("'square_size' must be a positive number.")
if (!is.numeric(cluster_sizes) || any(cluster_sizes <= 0))
stop("'cluster_sizes' must be a positive numeric vector.")
}
if (is.null(habitat) || is.null(habitat_names) || is.null(habitat_codes))
stop("'habitat', 'habitat_names', and 'habitat_codes' are required.")
if (length(habitat_names) != length(habitat_codes))
stop("Length of 'habitat_names' must equal length of 'habitat_codes'.")
if (is.null(classification))
stop("'classification' must be provided.")
if (ncol(classification) < 2)
stop("'classification' must have at least two columns: species names and one group column.")
# Assume first column contains species names
species_name_col <- names(classification)[1]
group_cols <- if (is.null(groups)) names(classification)[-1] else groups
# Check that all group columns exist
missing_cols <- setdiff(group_cols, names(classification))
if (length(missing_cols) > 0)
stop("The following group columns are not in classification: ",
paste(missing_cols, collapse = ", "))
#---------------------------- 2. Species group construction ------------------
# Species columns in data (after first three)
sp_cols <- 4:ncol(data)
sp_names <- colnames(data)[sp_cols]
n_sp <- length(sp_cols)
clean_sp <- tolower(trimws(sp_names))
if (verbose) message("Total species columns in data: ", n_sp)
# Clean classification species names
classif_sp <- classification[[species_name_col]]
clean_classif <- tolower(trimws(classif_sp))
# Build species groups for each selected group column
sp_groups <- list()
grp_names <- character()
for (col in group_cols) {
vals <- classification[[col]]
# For binary columns, we assume 1/TRUE indicates membership
if (is.logical(vals)) {
idx <- which(vals)
} else if (is.numeric(vals)) {
# If numeric, treat 1 as TRUE, everything else FALSE
idx <- which(vals == 1)
} else {
stop("Group column '", col, "' must be logical or numeric (0/1).")
}
sp_clean <- clean_classif[idx]
positions <- na.omit(match(sp_clean, clean_sp))
if (length(positions) > 0) {
sp_groups <- c(sp_groups, list(positions))
grp_names <- c(grp_names, paste0("Sp_", col))
if (verbose) message("  Group '", paste0("Sp_", col), "' has ", length(positions), " species.")
}
}
if (verbose) message("Created ", length(sp_groups), " species groups from classification.")
# Validate indices
for (i in seq_along(sp_groups)) {
if (any(sp_groups[[i]] < 1 | sp_groups[[i]] > n_sp))
stop("Internal error: group indices out of range.")
}
#---------------------------- 3. Helper functions ----------------------------
# ---- filter_points_in_expanding_circles ----
filter_points_in_expanding_circles <- function(points_sf, radius_vector, convex_hull) {
selected_point <- points_sf[sample(1:nrow(points_sf), 1), ]
points_within_circles <- list()
for (radius in radius_vector) {
circle <- sf::st_geometry(sf::st_buffer(selected_point, dist = radius))
intersection <- sf::st_intersection(circle, convex_hull)
circle_area <- as.numeric(sf::st_area(circle))
intersection_area <- as.numeric(sf::st_area(intersection))
if (intersection_area / circle_area < 0.5) break
points_in_circle <- points_sf[sf::st_intersects(points_sf, circle, sparse = FALSE), ]
points_within_circles[[paste0("radius_", radius)]] <-
list(points = points_in_circle, circle = circle)
}
return(points_within_circles)
}
# ---- summarize_samples (for circles) ----
summarize_samples <- function(samples, polygons, habitat_raster, habitat_names,
habitat_values, species_groups, species_group_names) {
n_hab <- length(habitat_names)
n_grp <- length(species_group_names)
results_df <- data.frame(matrix(0, nrow = length(samples),
ncol = n_hab + 1 + n_grp + 1))
colnames(results_df) <- c(habitat_names, "Area_Total", species_group_names, "Sp_Total")
for (i in seq_along(samples)) {
sample <- samples[[i]]
polygon <- polygons[[i]]
# Raster processing
habitat_cropped <- terra::crop(habitat_raster, terra::vect(polygon))
habitat_masked <- terra::mask(habitat_cropped, terra::vect(polygon))
habitat_df <- terra::freq(habitat_masked, bylayer = FALSE)
if (is.null(habitat_df)) habitat_df <- data.frame(value = NA, count = 0)
all_vals <- data.frame(value = habitat_values, count = 0)
for (j in 1:nrow(habitat_df)) {
idx <- which(all_vals$value == habitat_df$value[j])
if (length(idx) > 0) all_vals$count[idx] <- habitat_df$count[j]
}
cell_area <- terra::res(habitat_raster)[1] * terra::res(habitat_raster)[2]
all_vals$area <- all_vals$count * cell_area
for (j in 1:n_hab) results_df[i, j] <- all_vals$area[j]
results_df[i, n_hab + 1] <- sum(all_vals$area, na.rm = TRUE)
# Species data: after dropping geometry, first column is locationID, rest are species
if (inherits(sample, "sf")) sample_data <- sf::st_drop_geometry(sample)
else sample_data <- sample
if (ncol(sample_data) >= 2) {  # at least ID + one species
species_data <- sample_data[, -1, drop = FALSE]  # drop ID column, keep all species
} else {
species_data <- data.frame(matrix(0, nrow = nrow(sample_data), ncol = 0))
}
# Calculate species richness for each group
total_sp <- 0
for (k in seq_along(species_groups)) {
grp_idx <- species_groups[[k]]
valid <- grp_idx[grp_idx <= ncol(species_data)]
num_sp <- if (length(valid) > 0) {
sum(colSums(species_data[, valid, drop = FALSE] > 0, na.rm = TRUE) > 0)
} else 0
results_df[i, n_hab + 1 + k] <- num_sp
total_sp <- total_sp + num_sp
}
# Store total species as the sum of all group richness values
results_df[i, n_hab + n_grp + 2] <- total_sp
}
return(results_df)
}
# ---- create_squares ----
create_squares <- function(points_sf, width) {
if (!inherits(points_sf, "sf") || !inherits(sf::st_geometry(points_sf), "sfc_POINT"))
stop("Input must be an sf object with point geometries.")
half_width <- width / 2
squares_sf <- sf::st_as_sf(sf::st_buffer(points_sf, dist = half_width, endCapStyle = "SQUARE"))
return(squares_sf)
}
# ---- filter_points_in_clusters ----
filter_points_in_clusters <- function(points_sf, squares_sf, cluster_size_vector) {
npoints <- nrow(points_sf)
n_clusters_vector <- npoints %/% cluster_size_vector
n_clusters_vector[n_clusters_vector == 0] <- 1
points_within_clusters <- list()
for (i in seq_along(cluster_size_vector)) {
n_clusters <- n_clusters_vector[i]
size_val <- cluster_size_vector[i]
if (verbose) {
cat("\nDEBUG ========================================\n")
cat("DEBUG - Processing cluster size:", size_val, "->", n_clusters, "clusters\n")
cat("DEBUG - Total points available:", npoints, "\n")
}
if (n_clusters == npoints) {
# Each point is its own cluster
points_in_clusters <- split(points_sf, 1:npoints)
clusters_convex_hulls <- split(sf::st_geometry(squares_sf), 1:npoints)
if (verbose) {
cat("DEBUG - Individual points mode\n")
cat("DEBUG - Created", length(points_in_clusters), "individual clusters\n")
}
} else {
# Use k-means clustering
coords <- sf::st_coordinates(points_sf)
kmeans_result <- kmeans(coords, centers = n_clusters, iter.max = 100, nstart = 25)
# Get cluster assignments
cluster_assignments <- kmeans_result$cluster
if (verbose) {
cat("DEBUG - k-means clustering with", n_clusters, "centers\n")
cat("DEBUG - Cluster sizes:", paste(table(cluster_assignments), collapse=", "), "\n")
}
# Split points by cluster
points_in_clusters <- list()
squares_in_clusters <- list()
for (c in 1:n_clusters) {
# Get indices of points in this cluster
cluster_idx <- which(cluster_assignments == c)
# Subset points and squares
points_in_clusters[[c]] <- points_sf[cluster_idx, ]
squares_in_clusters[[c]] <- squares_sf[cluster_idx, ]
if (verbose) {
cat("DEBUG - Cluster", c, "has", length(cluster_idx), "points/squares\n")
}
}
# Verify all points are accounted for
total_points <- sum(sapply(points_in_clusters, nrow))
if (verbose) {
cat("DEBUG - Total points in clusters:", total_points, "(should be", npoints, ")\n")
}
# Merge all squares in each cluster and compute convex hull
clusters_convex_hulls <- list()
for (j in seq_along(squares_in_clusters)) {
n_sq <- nrow(squares_in_clusters[[j]])
if (n_sq == 0) {
warning("Cluster ", j, " has zero squares – skipping")
next
}
merged <- sf::st_union(squares_in_clusters[[j]])
hull <- sf::st_convex_hull(merged)
clusters_convex_hulls[[j]] <- hull
if (verbose) {
hull_area <- as.numeric(sf::st_area(hull))
cat("DEBUG - Cluster", j, ":", n_sq, "squares, hull area:", hull_area, "\n")
# For the largest cluster level, show more detail
if (size_val == max(cluster_size_vector)) {
cat("DEBUG -   Bounding box of hull:\n")
print(sf::st_bbox(hull))
}
}
}
}
# Store results
level_name <- paste0("size_", size_val)
points_within_clusters[[level_name]] <-
list(points = points_in_clusters, chulls = clusters_convex_hulls)
if (verbose) {
cat("DEBUG - Stored level:", level_name, "\n")
cat("DEBUG ========================================\n")
}
}
return(points_within_clusters)
}
# ---- summarize_clusters (modified to match original script) ----
summarize_clusters <- function(samples_list, chulls_list, habitat_raster, habitat_names,
habitat_values, species_groups, species_group_names, verbose) {
n_hab <- length(habitat_names)
n_grp <- length(species_group_names)
all_results <- data.frame()
for (level_name in names(samples_list)) {
level_samples <- samples_list[[level_name]]
level_chulls <- chulls_list[[level_name]]
n_clusters <- length(level_samples)
if (verbose) message("\nProcessing cluster level: ", level_name, " (", n_clusters, " clusters)")
for (clust_idx in 1:n_clusters) {
cluster_points <- level_samples[[clust_idx]]
cluster_hull <- level_chulls[[clust_idx]]
n_points <- nrow(cluster_points)
# Calculate TRUE polygon area (for reference, but not used as Area_Total)
polygon_area <- as.numeric(sf::st_area(cluster_hull))
row_data <- data.frame(matrix(0, nrow = 1, ncol = n_hab + 1 + n_grp + 1))
colnames(row_data) <- c(habitat_names, "Area_Total", species_group_names, "Sp_Total")
row_data$Cluster_ID <- paste0(level_name, "_", clust_idx)
row_data$Cluster_Level <- level_name
row_data$N_points <- n_points
# Habitat areas from raster
habitat_cropped <- terra::crop(habitat_raster, terra::vect(cluster_hull))
habitat_masked <- terra::mask(habitat_cropped, terra::vect(cluster_hull))
habitat_df <- terra::freq(habitat_masked, bylayer = FALSE)
# Add NA count manually (for "Other" if coded as NA)
na_count <- terra::global(habitat_masked, function(x) sum(is.na(x)))[1,1]
if (na_count > 0) {
habitat_df <- rbind(habitat_df, data.frame(value = NA, count = na_count))
}
if (is.null(habitat_df)) {
habitat_df <- data.frame(value = c(habitat_values, NA), count = 0)
}
all_vals <- data.frame(value = habitat_values, count = 0)
# Match frequencies to habitat values
for (j in 1:nrow(habitat_df)) {
val <- habitat_df$value[j]
if (is.na(val)) {
# This is NA count - handled below
} else {
idx <- which(all_vals$value == val)
if (length(idx) > 0) {
all_vals$count[idx] <- habitat_df$count[j]
}
}
}
cell_area <- terra::res(habitat_raster)[1] * terra::res(habitat_raster)[2]
all_vals$area <- all_vals$count * cell_area
# Store defined habitat areas
for (j in 1:n_hab) {
if (j <= nrow(all_vals)) {
row_data[1, j] <- all_vals$area[j]
}
}
# If "Other" is in habitat_names, calculate it as the area of NA cells
if ("Other" %in% habitat_names) {
other_idx <- which(habitat_names == "Other")
# Find NA count from habitat_df
na_idx <- which(is.na(habitat_df$value))
if (length(na_idx) > 0) {
other_area <- habitat_df$count[na_idx] * cell_area
} else {
other_area <- 0
}
row_data[1, other_idx] <- other_area
}
# Calculate Area_Total as SUM OF ALL HABITAT AREAS (including Other)
# This matches the original script's behavior
habitat_sum <- sum(all_vals$area, na.rm = TRUE)
if ("Other" %in% habitat_names) {
other_idx <- which(habitat_names == "Other")
habitat_sum <- habitat_sum + row_data[1, other_idx]
}
row_data[1, n_hab + 1] <- habitat_sum
# Species data
if (inherits(cluster_points, "sf")) {
sample_data <- sf::st_drop_geometry(cluster_points)
} else {
sample_data <- cluster_points
}
if (ncol(sample_data) >= 2) {
species_data <- sample_data[, -1, drop = FALSE]
} else {
species_data <- data.frame(matrix(0, nrow = nrow(sample_data), ncol = 0))
}
if (verbose && clust_idx == 1) {
message("    Cluster ", clust_idx, " has ", ncol(species_data), " species columns")
}
# Calculate species richness for each group
total_sp <- 0
for (k in seq_along(species_groups)) {
grp_idx <- species_groups[[k]]
valid <- grp_idx[grp_idx <= ncol(species_data)]
num_sp <- if (length(valid) > 0) {
sum(colSums(species_data[, valid, drop = FALSE] > 0, na.rm = TRUE) > 0)
} else 0
row_data[1, n_hab + 1 + k] <- num_sp
total_sp <- total_sp + num_sp
}
row_data[1, n_hab + n_grp + 2] <- total_sp
all_results <- rbind(all_results, row_data)
}
}
id_cols <- c("Cluster_ID", "Cluster_Level", "N_points")
data_cols <- setdiff(names(all_results), id_cols)
all_results <- all_results[, c(id_cols, data_cols)]
return(all_results)
}
# ---- SAR analysis function ----
analyze_sar <- function(results_table, habitat_names, method_used) {
sar_results <- list()
# Basic log-log plot data and linear model
sar_results$log_area <- log(results_table$Area_Total)
sar_results$log_sp <- log(results_table$Sp_Total)
# Fit linear model
sar_results$lm_model <- lm(log(Sp_Total) ~ log(Area_Total), data = results_table)
sar_results$lm_summary <- summary(sar_results$lm_model)
# For circles method, also prepare data for sar_countryside if requested
if (method_used == "circles") {
# Create dataframe for sar_countryside (remove unnecessary columns)
# This is a simplified version - users may need to customize which columns to remove
sar_results$sar_data <- results_table
} else {
# For clusters, we might want to aggregate by cluster level
# This is a placeholder - users may want different aggregation
sar_results$sar_data <- results_table
}
return(sar_results)
}
#---------------------------- 4. Main processing -----------------------------
points_sf <- sf::st_as_sf(data, coords = c("long", "lat"), crs = crs)
if (method == "circles") {
convex_hull <- sf::st_convex_hull(sf::st_union(points_sf))
samples <- filter_points_in_expanding_circles(points_sf, radii, convex_hull)
polygons <- lapply(samples, `[[`, "circle")
samples_points <- lapply(samples, `[[`, "points")
results_table <- summarize_samples(
samples = samples_points,
polygons = polygons,
habitat_raster = habitat,
habitat_names = habitat_names,
habitat_values = habitat_codes,
species_groups = sp_groups,
species_group_names = grp_names
)
# Perform SAR analysis
sar_analysis <- analyze_sar(results_table, habitat_names, method)
out <- list(
method = method,
results_table = results_table,
sar_analysis = sar_analysis,
points_sf = points_sf,
convex_hull = convex_hull,
samples = samples,
polygons = polygons
)
} else { # clusters
squares_sf <- create_squares(points_sf, square_size)
samples <- filter_points_in_clusters(points_sf, squares_sf, cluster_sizes)
samples_points <- lapply(samples, `[[`, "points")
clusters_chulls <- lapply(samples, `[[`, "chulls")
if (verbose) message("\nStarting cluster summarization...")
results_table <- summarize_clusters(
samples_list = samples_points,
chulls_list = clusters_chulls,
habitat_raster = habitat,
habitat_names = habitat_names,
habitat_values = habitat_codes,
species_groups = sp_groups,
species_group_names = grp_names,
verbose = verbose
)
# Perform SAR analysis
sar_analysis <- analyze_sar(results_table, habitat_names, method)
out <- list(
method = method,
results_table = results_table,
sar_analysis = sar_analysis,
points_sf = points_sf,
squares_sf = squares_sf,
samples = samples,
clusters_chulls = clusters_chulls
)
}
return(out)
}
